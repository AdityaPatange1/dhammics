# Copy to .env and adjust. Never commit real secrets.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=dhammics

# JWT — generate a long random string for production (e.g. openssl rand -hex 32)
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS: comma-separated origins, or * for dev only (must include the static site origin, e.g. npm run dev on 4174)
CORS_ORIGINS=http://127.0.0.1:4174,http://localhost:4174,http://127.0.0.1:5500,http://localhost:3000

# Optional first admin (created on first startup if no users exist)
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_DISPLAY_NAME=Admin

# Frontend bundle env (injected into assets/js/env-config.js).
# Only keys starting with DHAMMICS_ are embedded — other variables here are ignored by inject
# so you can keep tooling/backend secrets in the same file if needed.
# Run `npm run dev` / `npm run build` after editing, or: node scripts/inject-frontend-env.js

DHAMMICS_API_BASE=http://127.0.0.1:8000/api/v1

# Optional examples — read in JS via import { getEnv } from './assets/js/config.js'
# DHAMMICS_SITE_NAME=Dhammics
# DHAMMICS_FEATURE_COMMENTS=1

# CI/CD can set DHAMMICS_* without a file; they override .env when inject runs.
